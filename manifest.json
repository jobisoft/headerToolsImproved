{
  "manifest_version": 2,
  "name": "__MSG_extName__",
  "description": "Allows to modify the header and the source of messages.",
  "version": "5.0b4",
  "author": "Dillinger",
  "homepage_url": "https://addons.thunderbird.net/en-US/thunderbird/addon/header-tools-improved/",
  "default_locale": "en-US",
  "experiment_apis": {
    "LegacyPrefs": {
      "schema": "api/LegacyPrefs/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["LegacyPrefs"]],
        "script": "api/LegacyPrefs/implementation.js"
      }
    },
    "HeaderTools": {
      "schema": "api/HeaderTools/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["HeaderTools"]],
        "script": "api/HeaderTools/implementation.js"
      }
    }
  },
  "background": {
    "page": "background.html"
  },
  "options_ui": {
    "page": "options/options.html"
  },
  "commands": {
    "edit-headers": {
      "description": "__MSG_shortCut__"
    },
    "edit-source": {
      "description": "__MSG_shortCutFS__"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hdrtoolslite@dillinger",
      "update_url": "https://addons.phoenity.nl/updates.txt",
      "strict_min_version": "140.0"
    }
  },
  "icons": {
    "32": "hdrtools32.png"
  },
  "permissions": [
    "menus",
    "messagesRead",
    "accountsRead",
    "storage"
  ]
}
